---
const projects = [
  {
    category: 'Website',
    title: 'Promote Your Business',
    desc: 'A fast, mobile-friendly website for businesses ready to establish their online presence.',    
    href: '/bit-voyager/work/small-business-site',
    accent: 'var(--accent-cyan)',
    border: 'rgba(6,182,212,0.25)',
    glow: 'rgba(6,182,212,0.13)',
    icon: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
    items: [
      '100% custom-built — no Wix, Squarespace, or page builders',
      'Easy content updates with a built-in CMS',
      'Mobile-friendly on every device',
      'SEO-ready from day one',
      'Delivered in 2–3 weeks',
    ],
  },
  {
    category: 'Enterprise Application',
    title: 'Run Your Business',
    desc: 'Custom software that streamlines your operations and gives your team the tools they need to work more efficiently.',
    href: '/bit-voyager/work/client-portal',
    accent: 'var(--accent-purple)',
    border: 'rgba(124,58,237,0.35)',
    glow: 'rgba(124,58,237,0.17)',
    icon: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
    items: [
      'Secure user accounts with role-based permissions',
      'Custom dashboards and third-party integrations',
      'Automated workflows tailored to your business',
      'Timeline and scope customized to your project',
      'Built to scale as your business grows',
      'Reliable, cloud-hosted infrastructure',
    ],
  },
  {
    category: 'Infrastructure & Consulting',
    title: 'Power Your Business',
    desc: 'From cloud infrastructure to on-site hardware, we help businesses build, optimize, and maintain the technology they rely on every day.',
    href: '/bit-voyager/work/aws-setup',
    accent: 'var(--accent-gold)',
    border: 'rgba(245,158,11,0.25)',
    glow: 'rgba(245,158,11,0.13)',
    icon: '<path d="M5.5 17.5 C4 13 6 11 9 12 C9 8 11 6 12.5 6 C14 6 16 8 16 12 C19 11 21 14 19.5 17.5 Q16 21 12.5 21 Q9 21 5.5 17.5 Z"/>',
    items: [
      'Cloud and on-premises infrastructure',
      'Technical consulting and architecture guidance',
      'Server, workstation, and network setup',
      'Performance, security, and reliability improvements',
      'Technology planning for future growth',
    ],
  },
];
---

<section id="services" aria-labelledby="work-heading" class="services-section">
  <div class="container">
    <div class="fade-in section-header">
      <p class="eyebrow">// SERVICES</p>
      <h2 id="work-heading">What We Do</h2>
      <p class="subtitle">Thoughtfully designed. Expertly engineered.</p>
    </div>

    <div class="services-grid">
      {projects.map((project, i) => (
        <article
          class="glass-card fade-in services-card"
          style={`transition-delay: ${i * 0.1}s; --accent: ${project.accent}; --border: ${project.border}; --glow: ${project.glow};`}
          aria-label={project.title}
        >
          <div class="card-header">
            <div class="card-icon" style={`color: ${project.accent};`}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={project.icon} />
            </div>
            <p class="category" style={`color: ${project.accent};`}>{project.category}</p>
          </div>
          <h3>{project.title}</h3>
          <p class="desc">{project.desc}</p>

          <ul class="tier-items">
            {project.items.map(item => (
              <li>
                <span class="check" style={`color: ${project.accent};`}>✓</span>
                {item}
              </li>
            ))}
          </ul>

          <a href={project.href} class="learn-more" style={`color: ${project.accent};`}>
            Learn more →
          </a>
        </article>
      ))}
    </div>

    <p class="fade-in disclaimer">
      These represent the types of projects we build. Reach out to discuss your specific needs.
    </p>
  </div>
</section>

<style>
  .services-section {
    padding: 120px 24px;
    background: linear-gradient(to bottom, var(--bg-surface), var(--bg-base) 12%, var(--bg-base));
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .eyebrow {
    font-size: 0.8rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 16px;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 40px;
  }

  .services-card {
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-color: var(--border) !important;
    background: var(--glow) !important;
    box-shadow: 0 0 40px var(--glow), 0 1px 0 var(--border) inset;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .card-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .card-icon svg {
    width: 100%;
    height: 100%;
  }

  .category {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  h3 {
    font-size: 1.15rem;
    color: var(--text-primary);
    margin: 0;
  }

  .desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .tier-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .tier-items li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    color: var(--text-primary);
  }

  .check {
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .learn-more {
    font-size: 0.8rem;
    text-decoration: none;
    margin-top: 4px;
    opacity: 0.85;
    transition: opacity 0.2s;
  }

  .learn-more:hover {
    opacity: 1;
  }

  .disclaimer {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    opacity: 0.6;
  }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
