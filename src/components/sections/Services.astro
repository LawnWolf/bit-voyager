---
const services = [
  {
    icon: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
    title: 'Web & Digital Experiences',
    desc: 'From pixel-perfect landing pages to complex web apps that delight and convert.',
  },
  {
    icon: '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v8h4"/><path d="M18 9h2a2 2 0 0 1 2 2v11h-4"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/>',
    title: 'Enterprise Applications',
    desc: 'Full-featured platforms with the power of AWS baked in — built for the long game.',
  },
  {
    icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
    title: 'High Availability Architecture',
    desc: 'Redundant, load-balanced, fault-tolerant by design. Because downtime is not an option.',
  },
  {
    icon: '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
    title: 'Auto-Scaling Infrastructure',
    desc: 'Grows with your business — no traffic spike too big, no resource wasted at rest.',
  },
  {
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>',
    title: 'Security & Compliance',
    desc: 'Enterprise-grade security from day one. Audits, encryption, access control — all baked in.',
  },
  {
    icon: '<line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>',
    title: 'DevOps & CI/CD',
    desc: 'Continuous delivery pipelines that ship fast, safe, and repeatably every time.',
  },
];
---

<section id="services" aria-labelledby="services-heading" class="services-section">
  <div class="container">
    <div class="fade-in section-header">
      <p class="eyebrow">// SERVICES</p>
      <h2 id="services-heading">What We Build</h2>
      <p class="subtitle">End-to-end solutions engineered for performance, resilience, and growth.</p>
    </div>

    <div class="services-grid">
      {services.map((service, i) => (
        <article
          class="glass-card fade-in service-card"
          style={`transition-delay: ${i * 0.08}s;`}
          aria-label={service.title}
        >
          <div class="service-title-row">
            <div class="service-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={service.icon}
              />
            </div>
            <h3>{service.title}</h3>
          </div>
          <p>{service.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 120px 24px;
    background: linear-gradient(to bottom, var(--bg-base), var(--bg-surface) 12%, var(--bg-surface) 88%, var(--bg-base));
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .eyebrow {
    font-size: 0.8rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 16px;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .service-card {
    padding: 32px;
  }

  .service-title-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .service-title-row h3 {
    margin-bottom: 0;
  }

  .service-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--accent-cyan);
  }

  .service-icon svg {
    width: 100%;
    height: 100%;
  }

  h3 {
    font-size: 1.1rem;
    margin-bottom: 0;
    color: var(--text-primary);
  }

  p {
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
