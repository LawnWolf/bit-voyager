---
const projects = [
  {
    category: 'Website',
    title: 'Local Service Business',
    desc: 'A fast, mobile-friendly website for a local service company — booking form, SEO-optimised pages, and Google Maps integration. Delivered in two weeks.',
    href: '/bit-voyager/work/small-business-site',
    accent: 'var(--accent-cyan)',
    border: 'rgba(6,182,212,0.25)',
    glow: 'rgba(6,182,212,0.13)',
    icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
    items: [
      '100% custom-coded — no Wix, Squarespace, or page builders',
      'CMS included so you update content without touching code',
      'Mobile-responsive design',
      'Basic SEO setup',
      'Delivered in 2–3 weeks',
    ],
  },
  {
    category: 'Enterprise Application',
    title: 'Client Portal & Dashboard',
    desc: 'A custom web app letting a small business manage client requests, track project status, and share files — replacing a patchwork of emails and spreadsheets.',
    href: '/bit-voyager/work/client-portal',
    accent: 'var(--accent-purple)',
    border: 'rgba(124,58,237,0.35)',
    glow: 'rgba(124,58,237,0.17)',
    icon: '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
    items: [
      'Scales automatically to match demand, improving performance while reducing cost',
      'High availability with automatic failover',
      'User authentication & role-based access',
      'Dashboards & third-party integrations',
      'Complex workflows and business logic',
      'Timeline scoped to project',
    ],
  },
  {
    category: 'Cloud & Hosting',
    title: 'AWS Infrastructure Setup',
    desc: 'Moved a growing business off shared hosting onto AWS — auto-scaling, daily backups, SSL, and a CI/CD pipeline so deploys happen with a single git push.',
    href: '/bit-voyager/work/aws-setup',
    accent: 'var(--accent-gold)',
    border: 'rgba(245,158,11,0.25)',
    glow: 'rgba(245,158,11,0.13)',
    icon: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>',
    items: [
      'AWS account setup & IAM',
      'Auto-scaling infrastructure',
      'CI/CD pipeline',
      'Monitoring & alerting',
      'Monthly retainer available',
    ],
  },
];
---

<section id="services" aria-labelledby="work-heading" class="services-section">
  <div class="container">
    <div class="fade-in section-header">
      <p class="eyebrow">// SERVICES</p>
      <h2 id="work-heading">What We Build</h2>
      <p class="subtitle">A sample of the kinds of projects we take on.</p>
    </div>

    <div class="services-grid">
      {projects.map((project, i) => (
        <article
          class="glass-card fade-in services-card"
          style={`transition-delay: ${i * 0.1}s; --accent: ${project.accent}; --border: ${project.border}; --glow: ${project.glow};`}
          aria-label={project.title}
        >
          <p class="category" style={`color: ${project.accent};`}>{project.category}</p>
          <div class="card-header">
            <div class="card-icon" style={`color: ${project.accent};`}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={project.icon} />
            </div>
            <h3>{project.title}</h3>
          </div>
          <p class="desc">{project.desc}</p>

          <ul class="tier-items">
            {project.items.map(item => (
              <li>
                <span class="check" style={`color: ${project.accent};`}>✓</span>
                {item}
              </li>
            ))}
          </ul>

          <a href={project.href} class="learn-more" style={`color: ${project.accent};`}>
            Learn more →
          </a>
        </article>
      ))}
    </div>

    <p class="fade-in disclaimer">
      These represent the types of projects we build. Reach out to discuss your specific needs.
    </p>
  </div>
</section>

<style>
  .services-section {
    padding: 120px 24px;
    background: linear-gradient(to bottom, var(--bg-surface), var(--bg-base) 12%, var(--bg-base));
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .eyebrow {
    font-size: 0.8rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 16px;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 40px;
  }

  .services-card {
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-color: var(--border) !important;
    background: var(--glow) !important;
    box-shadow: 0 0 40px var(--glow), 0 1px 0 var(--border) inset;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .card-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .card-icon svg {
    width: 100%;
    height: 100%;
  }

  .category {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0;
  }

  h3 {
    font-size: 1.15rem;
    color: var(--text-primary);
    margin: 0;
  }

  .desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .tier-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .tier-items li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    color: var(--text-primary);
  }

  .check {
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .learn-more {
    font-size: 0.8rem;
    text-decoration: none;
    margin-top: 4px;
    opacity: 0.85;
    transition: opacity 0.2s;
  }

  .learn-more:hover {
    opacity: 1;
  }

  .disclaimer {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    opacity: 0.6;
  }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
