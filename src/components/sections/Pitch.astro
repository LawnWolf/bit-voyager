---
const differentiators = [
  {
    title: '30+ Years of Experience',
    desc: 'Two senior engineers. No juniors, no hand-offs, no learning on your dime.',
    icon: '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/>',
  },
  {
    title: 'Senior-Level Engineers',
    desc: 'Decades of hands-on experience building reliable software across a wide range of technologies and industries.',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>',
  },
  {
    title: '100% Custom Built',
    desc: 'No templates. No page builders. Just clean, maintainable software you own.',
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  },
  {
    title: 'End-to-End Solutions',
    desc: 'From strategy and design to deployment and support — one team from start to finish.',
    icon: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>',
  },
  {
    title: 'Built to Scale',
    desc: 'Built to grow with your business—from your first customer to your ten-thousandth.',
    icon: '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>',
  },
  {
    title: 'Direct Communication',
    desc: 'Always work directly with the engineers building your project — not salespeople or account managers.',
    icon: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  },
];
---

<section id="why-bit-voyager" aria-labelledby="why-heading" class="why-section">
  <div class="container">
    <div class="fade-in section-header">
      <p class="eyebrow">// DIFFERENTIATORS</p>
      <h2 id="why-heading">Why Bit Voyager?</h2>
      <p class="lead-statement">Quality over quantity. Every time.</p>
    </div>

    <div class="differentiators-grid">
      {differentiators.map((item, i) => (
        <article
          class="glass-card fade-in diff-card"
          style={`transition-delay: ${i * 0.1}s;`}
        >
          <div class="diff-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
          </div>
          <h3>{item.title}</h3>
          <p class="diff-desc">{item.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why-section {
    padding: 120px 24px;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .eyebrow {
    font-size: 0.8rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 16px;
  }

  .lead-statement {
    font-size: 1.15rem;
    color: var(--text-muted);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .differentiators-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 24px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .diff-card {
    grid-column: span 2;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .diff-icon {
    width: 28px;
    height: 28px;
    color: var(--accent-cyan);
    flex-shrink: 0;
  }

  .diff-icon svg {
    width: 100%;
    height: 100%;
  }

  h3 {
    font-size: 1.05rem;
    color: var(--text-primary);
    margin: 0;
  }

  .diff-desc {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .differentiators-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .diff-card,
    .diff-card:nth-child(4),
    .diff-card:nth-child(5) {
      grid-column: span 1;
    }
  }

  @media (max-width: 640px) {
    .differentiators-grid { grid-template-columns: 1fr; }
  }
</style>
