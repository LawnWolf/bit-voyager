---
const stats = [
  { value: '30+', label: 'Years of combined engineering experience' },
  { value: 'NASA', label: 'Where we built our craft' },
  { value: '24 hrs', label: 'Response time guarantee' },
  { value: '2–3 wks', label: 'Typical simple website delivery' },
];

const features = [
  '100% custom-coded — no Wix, Squarespace, or page builders',
  'Clean, maintainable code you own outright',
  'Mobile-first, SEO-friendly by default',
  'Transparent project tracking',
  'Ongoing support & maintenance available',
];
---

<section id="why-bit-voyager" aria-labelledby="why-heading" class="why-section">
  <div class="container">
    <div class="fade-in section-header">
      <p class="eyebrow">// DIFFERENTIATORS</p>
      <h2 id="why-heading">Why Bit Voyager?</h2>
      <p class="lead-statement">We're NASA engineers. We build things that have to work.</p>
    </div>

    <div class="stats-grid">
      {stats.map((stat, i) => (
        <div class="glass-card fade-in stat-block" style={`transition-delay: ${i * 0.1}s;`}>
          <p class="stat-value gradient-text">{stat.value}</p>
          <p class="stat-label">{stat.label}</p>
        </div>
      ))}
    </div>

    <div class="fade-in features-grid">
      {features.map((feature) => (
        <div class="feature-item">
          <span class="check">✓</span>
          <span>{feature}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why-section {
    padding: 120px 24px;
    background: linear-gradient(to bottom, var(--bg-surface), var(--bg-base) 12%, var(--bg-base));
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .eyebrow {
    font-size: 0.8rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 16px;
  }

  .lead-statement {
    font-size: 1.15rem;
    color: var(--text-muted);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 80px;
  }

  .stat-block {
    padding: 40px 24px;
    text-align: center;
  }

  .stat-value {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 12px;
    line-height: 1;
  }

  .stat-label {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
    max-width: 900px;
    margin: 0 auto;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .check {
    color: var(--accent-cyan);
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .feature-item span:last-child {
    color: var(--text-primary);
    font-size: 0.95rem;
  }

  @media (max-width: 1024px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
