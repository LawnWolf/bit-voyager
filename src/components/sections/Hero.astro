---
import logoSrc from '../../assets/bit-voyager-white.svg?url';
---

<section
  id="home"
  aria-label="Hero"
  class="nebula-bg hero-section"
>
  <canvas aria-hidden="true" class="star-canvas"></canvas>
  <div class="glow-orb glow-cyan" aria-hidden="true"></div>
  <div class="glow-orb glow-purple" aria-hidden="true"></div>

  <div class="hero-content">

    <div class="company-name">
      <img src={logoSrc} alt="" aria-hidden="true" class="company-logo" />
      <span class="name-group">
        <span class="name-text">bit voyager</span>
        <span class="tagline">Charting Your Digital Journey</span>
      </span>
    </div>

    <p class="cycle-line">
      We build <span id="cycle-word" class="cycle-word"></span><span class="type-cursor"></span> for your business.
    </p>

    <div class="cta-row">
      <a href="#contact" class="btn-primary">Launch a Project</a>
      <a href="#work" class="btn-ghost">See Our Work</a>
    </div>
  </div>

  <div class="scroll-indicator-wrap" aria-hidden="true">
    <div class="scroll-indicator"></div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 160px;
    position: relative;
    overflow: hidden;
  }

  .star-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .glow-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    filter: blur(90px);
  }

  .glow-cyan {
    width: 700px;
    height: 500px;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(6,182,212,0.14) 0%, transparent 70%);
  }

  .glow-purple {
    width: 500px;
    height: 500px;
    bottom: 80px;
    right: -100px;
    background: radial-gradient(ellipse, rgba(124,58,237,0.1) 0%, transparent 70%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 100px;
    padding: 6px 16px;
    margin-bottom: 28px;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-cyan);
    box-shadow: 0 0 8px var(--accent-cyan);
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  .company-name {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3em;
  }

  .company-logo {
    height: 2.4em;
    width: auto;
    flex-shrink: 0;
    filter: drop-shadow(0 0 12px rgba(6,182,212,0.3));
  }

  .name-group {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .name-text {
    display: block;
  }

  .tagline {
    font-weight: 500;
    letter-spacing: 0.04em;
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-top: 20px;
    white-space: nowrap;
    display: block;
  }

  .cycle-line {
    font-size: clamp(1.2rem, 3vw, 1.7rem);
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 48px;
  }

  .cycle-word {
    color: var(--accent-cyan);
    font-weight: 700;
  }

  .type-cursor {
    display: inline-block;
    width: 2px;
    height: 0.85em;
    background: var(--accent-cyan);
    margin: 0 1px;
    vertical-align: middle;
    animation: blink-cur 1s step-end infinite;
  }

  @keyframes blink-cur {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .cta-row {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .scroll-indicator-wrap {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
  }

  .scroll-indicator {
    width: 24px;
    height: 40px;
    border: 2px solid rgba(255,255,255,0.2);
    border-radius: 12px;
    position: relative;
  }

  .scroll-indicator::after {
    content: '';
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 8px;
    border-radius: 2px;
    background: var(--accent-cyan);
    animation: scrollDot 1.8s ease-in-out infinite;
  }

  @keyframes scrollDot {
    0% { opacity: 1; transform: translateX(-50%) translateY(0); }
    80% { opacity: 0; transform: translateX(-50%) translateY(14px); }
    100% { opacity: 0; transform: translateX(-50%) translateY(0); }
  }
</style>

<script is:inline>
  function matchTaglineWidth() {
    const nameText = document.querySelector('.name-text');
    const tagline = document.querySelector('.tagline');
    if (!nameText || !tagline) return;
    const target = nameText.offsetWidth;
    let lo = 8, hi = 300;
    for (let i = 0; i < 30; i++) {
      const mid = (lo + hi) / 2;
      tagline.style.fontSize = mid + 'px';
      if (tagline.offsetWidth < target) lo = mid; else hi = mid;
    }
    tagline.style.fontSize = lo + 'px';
  }

  document.addEventListener('DOMContentLoaded', () => {
    matchTaglineWidth();
    window.addEventListener('resize', matchTaglineWidth);

    const section = document.getElementById('home');
    const canvas = section.querySelector('.star-canvas');
    const ctx = canvas.getContext('2d');

    const STAR_COUNT = 120;
    const stars = [];

    function init() {
      canvas.width = section.offsetWidth;
      canvas.height = section.offsetHeight;
      stars.length = 0;
      for (let i = 0; i < STAR_COUNT; i++) {
        stars.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          r: Math.random() * 1.5 + 0.5,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.8 + 0.3,
        });
      }
    }

    function draw(t) {
      const sec = t * 0.001;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (const s of stars) {
        const alpha = 0.15 + 0.85 * (0.5 + 0.5 * Math.sin(sec * s.speed + s.phase));
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(220, 235, 255, ${alpha.toFixed(3)})`;
        ctx.fill();
      }
      requestAnimationFrame(draw);
    }

    init();
    window.addEventListener('resize', init);
    requestAnimationFrame(draw);

    // Typewriter word cycling
    const words = ['websites', 'enterprise apps', 'cloud infrastructure'];
    let wordIdx = 0;
    let charIdx = 0;
    let deleting = false;
    const wordEl = document.getElementById('cycle-word');

    function typeLoop() {
      const current = words[wordIdx];
      if (!deleting) {
        charIdx++;
        wordEl.textContent = current.slice(0, charIdx);
        if (charIdx === current.length) {
          setTimeout(() => { deleting = true; typeLoop(); }, 1800);
          return;
        }
        setTimeout(typeLoop, 70 + Math.random() * 50);
      } else {
        charIdx--;
        wordEl.textContent = current.slice(0, charIdx);
        if (charIdx === 0) {
          deleting = false;
          wordIdx = (wordIdx + 1) % words.length;
          setTimeout(typeLoop, 350);
          return;
        }
        setTimeout(typeLoop, 40);
      }
    }

    setTimeout(typeLoop, 600);
  });
</script>
