---
const team = [
  {
    initials: 'BP',
    name: 'Bill Pateracki',
    badge: 'Software Engineer',
    role: "Senior Software Engineer with 17+ years of full-stack software development and user experience. Bill builds modern websites and enterprise applications from end-to-end, combining thoughtful design with dependable engineering to create software that's both beautiful and reliable.",
    accent: 'var(--accent-cyan)',
    gradient: 'linear-gradient(135deg, #06B6D4, #0891B2)',
  },
  {
    initials: 'BC',
    name: 'Bruno Capo de Sa',
    badge: 'System Engineer',
    role: "Systems Engineer and Systems Administrator with 15+ years of experience designing and maintaining secure, high-performance infrastructure. Bruno builds the cloud and on-premises foundations that keep businesses secure, running smoothly, and ready to grow",
    accent: 'var(--accent-purple)',
    gradient: 'linear-gradient(135deg, #7C3AED, #5B21B6)',
  },
];
---

<section id="team" aria-labelledby="team-heading" class="team-section">
  <div class="container">
    <div class="fade-in section-header">
      <p class="eyebrow">// MEET THE TEAM</p>
      <h2 id="team-heading">Who We Are</h2>
      <p class="subtitle">Small ship. Massive range. Fueled by ambition.</p>
    </div>

    <div class="team-grid">
      {team.map((member, i) => (
        <article
          class="glass-card fade-in team-card"
          style={`transition-delay: ${i * 0.12}s;`}
          aria-label={`${member.name} — team member`}
        >
          <div class="card-top-border" style={`background: ${member.gradient};`}></div>

          <div class="card-body">
            <div class="card-header">
              <div class="avatar" style={`background: ${member.gradient};`}>
                {member.initials}
              </div>
              <div class="name-block">
                <h3>{member.name}</h3>
                <span class="badge" style={`border-color: ${member.accent}; color: ${member.accent};`}>
                  {member.badge}
                </span>
              </div>
            </div>

            <p class="bio">{member.role}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team-section {
    padding: 120px 24px;
    background: var(--bg-base);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 72px;
  }

  .eyebrow {
    font-size: 0.8rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 16px;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }

  .team-card {
    padding: 0;
    overflow: hidden;
  }

  .card-top-border {
    height: 3px;
  }

  .card-body {
    padding: 36px 32px;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 20px;
  }

  .avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.1rem;
    color: #fff;
    flex-shrink: 0;
  }

  .name-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  h3 {
    font-size: 1.25rem;
    margin: 0;
  }

  .badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 100px;
    border: 1px solid;
    letter-spacing: 0.02em;
    align-self: flex-start;
  }

  .bio {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .team-grid { grid-template-columns: 1fr; }
  }
</style>
