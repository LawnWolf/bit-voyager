---
const tiers = [
  {
    name: 'Simple Website',
    range: '$1,500 – $4,000',
    description: 'A clean, fast website for small businesses ready to establish their online presence.',
    items: [
      '100% custom-coded — no Wix, Squarespace, or page builders',
      'CMS included so you update content without touching code',
      'Up to 6 pages',
      'Mobile-responsive design',
      'Basic SEO setup',
      'Delivered in 2–3 weeks',
    ],
    accent: 'var(--accent-cyan)',
    border: 'rgba(6,182,212,0.25)',
    glow: 'rgba(6,182,212,0.08)',
    featured: false,
  },
  {
    name: 'Enterprise Application',
    range: 'Starting at $5,000',
    description: "Full-scale web applications built for performance, reliability, and growth — not just today's needs.",
    items: [
      'Scales automatically to match demand, improving performance while reducing cost',
      'High availability with automatic failover',
      'User authentication & role-based access',
      'Dashboards & third-party integrations',
      'Complex workflows and business logic',
      'Timeline scoped to project',
    ],
    accent: 'var(--accent-purple)',
    border: 'rgba(124,58,237,0.35)',
    glow: 'rgba(124,58,237,0.12)',
    featured: true,
  },
  {
    name: 'Cloud & Hosting',
    range: 'Custom quote',
    description: 'Managed AWS infrastructure — from initial setup to ongoing monitoring and support.',
    items: [
      'AWS account setup & IAM',
      'Auto-scaling infrastructure',
      'CI/CD pipeline',
      'Monitoring & alerting',
      'Monthly retainer available',
    ],
    accent: 'var(--accent-gold)',
    border: 'rgba(245,158,11,0.25)',
    glow: 'rgba(245,158,11,0.08)',
    featured: false,
  },
];
---

<section id="pricing" aria-labelledby="pricing-heading" class="pricing-section">
  <div class="container">
    <div class="fade-in section-header">
      <p class="eyebrow">// PRICING</p>
      <h2 id="pricing-heading">What to Expect</h2>
      <p class="subtitle">Every project is different, so we scope before we quote. These ranges set the ballpark.</p>
    </div>

    <div class="pricing-grid">
      {tiers.map((tier, i) => (
        <div
          class={`glass-card fade-in pricing-card${tier.featured ? ' featured' : ''}`}
          style={`transition-delay: ${i * 0.1}s; --accent: ${tier.accent}; --border: ${tier.border}; --glow: ${tier.glow};`}
        >
          {tier.featured && <div class="featured-badge">Most Popular</div>}
          <p class="tier-name" style={`color: ${tier.accent};`}>{tier.name}</p>
          <p class="tier-range">{tier.range}</p>
          <p class="tier-desc">{tier.description}</p>

          <ul class="tier-items">
            {tier.items.map(item => (
              <li>
                <span class="check" style={`color: ${tier.accent};`}>✓</span>
                {item}
              </li>
            ))}
          </ul>

          <a href="#contact" class={tier.featured ? 'btn-primary tier-cta' : 'btn-ghost tier-cta'}>
            Launch a Project
          </a>
        </div>
      ))}
    </div>

    <p class="fade-in note">
      Prices are estimates in USD. Final cost depends on scope, complexity, and timeline. All projects start with a free discovery call.
    </p>
  </div>
</section>

<style>
  .pricing-section {
    padding: 120px 24px;
    background: linear-gradient(to bottom, var(--bg-base), var(--bg-surface) 12%, var(--bg-surface) 88%, var(--bg-base));
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .eyebrow {
    font-size: 0.8rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 16px;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 540px;
    margin: 0 auto;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
    margin-bottom: 40px;
  }

  .pricing-card {
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    border-color: var(--border) !important;
  }

  .pricing-card.featured {
    background: var(--glow) !important;
    border-color: var(--border) !important;
    box-shadow: 0 0 40px var(--glow), 0 1px 0 var(--border) inset;
  }

  .featured-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent-purple);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 4px 14px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .tier-name {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  .tier-range {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.2;
  }

  .tier-desc {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.65;
    margin: 0;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .tier-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .tier-items li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    color: var(--text-primary);
  }

  .check {
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .tier-cta {
    display: block;
    text-align: center;
    margin-top: 8px;
    width: 100%;
    justify-content: center;
  }

  .note {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.82rem;
    opacity: 0.55;
    max-width: 600px;
    margin: 0 auto;
  }

  @media (max-width: 1024px) {
    .pricing-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .pricing-grid { grid-template-columns: 1fr; }
  }
</style>
