---
---

<section id="cta" aria-label="Call to action" class="nebula-bg cta-section">
  <canvas aria-hidden="true" class="star-canvas"></canvas>
  <div class="cta-inner">
    <div class="fade-in">
      <p class="eyebrow">// LET'S BUILD</p>
      <h2>
        Ready to Build Something
        <span class="gradient-text"> Extraordinary?</span>
      </h2>
      <p class="subtext">
        Whether it's a landing page or a planet-scale platform — we're ready.
      </p>
      <a href="#contact" class="btn-primary cta-btn">
        Launch a Project →
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 120px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .star-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .cta-inner {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
  }

  .eyebrow {
    font-size: 0.8rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    margin-bottom: 20px;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 20px;
    letter-spacing: -0.03em;
  }

  .subtext {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 40px;
    line-height: 1.7;
  }

  .cta-btn {
    font-size: 1.1rem;
    padding: 16px 36px;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('cta');
    const canvas = section.querySelector('.star-canvas');
    const ctx = canvas.getContext('2d');

    const STAR_COUNT = 120;
    const stars = [];

    function init() {
      canvas.width = section.offsetWidth;
      canvas.height = section.offsetHeight;
      stars.length = 0;
      for (let i = 0; i < STAR_COUNT; i++) {
        stars.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          r: Math.random() * 1.5 + 0.5,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.8 + 0.3,
        });
      }
    }

    function draw(t) {
      const sec = t * 0.001;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (const s of stars) {
        const alpha = 0.15 + 0.85 * (0.5 + 0.5 * Math.sin(sec * s.speed + s.phase));
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(220, 235, 255, ${alpha.toFixed(3)})`;
        ctx.fill();
      }
      requestAnimationFrame(draw);
    }

    init();
    window.addEventListener('resize', init);
    requestAnimationFrame(draw);
  });
</script>
