---
const steps = [
  { num: '01', title: 'Discovery', desc: 'We start by understanding your business, goals, and challenges so we can recommend the right solution—not just the easiest one.' },
  { num: '02', title: 'Design', desc: 'We create a thoughtful plan for your project, ensuring it\'s built to perform today and adapt as your business grows.' },
  { num: '03', title: 'Build', desc: 'We develop your solution with regular updates, open communication, and no surprises along the way.' },
  { num: '04', title: 'Launch & Support', desc: 'Once everything is ready, we launch with confidence and remain available to support, improve, and expand your solution over time.' },
];
---

<section id="process" aria-labelledby="process-heading" class="process-section">
  <div class="container">
    <div class="fade-in section-header">
      <p class="eyebrow">// THE PROCESS</p>
      <h2 id="process-heading">How We Work</h2>
    </div>

    <div class="process-grid">
      {steps.map((step, i) => (
        <div class="fade-in process-step" style={`transition-delay: ${i * 0.1}s;`}>
          {i < steps.length - 1 && <div class="process-line" aria-hidden="true"></div>}

          <div class="step-circle">{step.num}</div>

          <div class="glass-card step-card">
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-section {
    padding: 120px 24px;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .eyebrow {
    font-size: 0.8rem;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3rem);
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    position: relative;
  }

  .process-step {
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
  }

  .process-line {
    position: absolute;
    top: 32px;
    left: calc(50% + 32px);
    width: calc(100% + 24px - 64px);
    height: 0;
    border-top: 2px dashed rgba(124, 58, 237, 0.35);
    z-index: 0;
  }

  .step-circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-cyan));
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 1rem;
    color: #fff;
    margin: 0 auto 20px;
    box-shadow: 0 0 24px rgba(124, 58, 237, 0.4);
    position: relative;
    z-index: 1;
  }

  .step-card {
    padding: 24px;
    flex: 1;
    text-align: left;
  }

  h3 {
    font-size: 1.05rem;
    margin-bottom: 10px;
    color: var(--text-primary);
  }

  p {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.65;
  }

  @media (max-width: 1024px) {
    .process-grid { grid-template-columns: repeat(2, 1fr); }
    .process-line { display: none; }
  }

  @media (max-width: 640px) {
    .process-grid { grid-template-columns: 1fr; }
  }
</style>
