---
import logoSrc from '../assets/bit-voyager-white.svg?url';

const navLinks = [
  { label: 'Home', href: '#home' },
  { label: 'Services', href: '#services' },
  { label: 'Why Us', href: '#pitch' },
  { label: 'Process', href: '#process' },
  { label: 'Team', href: '#team' },
  { label: 'Contact', href: '#contact' },
];
---

<nav
  aria-label="Main navigation"
  style="
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    background: rgba(5, 8, 16, 0.75);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  "
>
  <!-- Top bar -->
  <div style="
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  ">
    <!-- Logo -->
    <a
      href="#home"
      aria-label="Bit Voyager home"
      style="
        font-weight: 700;
        font-size: 1.35rem;
        letter-spacing: -0.02em;
        color: var(--text-primary);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 6px;
      "
    >
      <img src={logoSrc} alt="" aria-hidden="true" class="company-logo" />
      bit voyager
    </a>

    <!-- Desktop nav links -->
    <ul role="list" class="nav-links" style="
      display: flex;
      align-items: center;
      gap: 32px;
      list-style: none;
      margin: 0;
      padding: 0;
    ">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-link"
            style="
              font-size: 0.9rem;
              font-weight: 500;
              color: var(--text-muted);
              text-decoration: none;
              transition: color 0.2s ease;
            "
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTA -->
    <a
      href="#contact"
      class="nav-cta desktop-cta"
      style="
        font-weight: 600;
        font-size: 0.9rem;
        padding: 10px 20px;
        border-radius: 8px;
        border: 1px solid transparent;
        background:
          linear-gradient(var(--bg-surface), var(--bg-surface)) padding-box,
          linear-gradient(135deg, var(--accent-purple), var(--accent-cyan)) border-box;
        color: var(--text-primary);
        text-decoration: none;
        transition: opacity 0.2s ease, transform 0.2s ease;
        white-space: nowrap;
      "
    >
      Launch a Project
    </a>

    <!-- Hamburger (mobile only) -->
    <button
      id="hamburger-btn"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      style="
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 36px;
        height: 36px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
      "
    >
      <span class="bar" style="display:block;width:22px;height:2px;background:var(--text-primary);border-radius:2px;transition:transform 0.25s ease,opacity 0.25s ease;"></span>
      <span class="bar" style="display:block;width:22px;height:2px;background:var(--text-primary);border-radius:2px;transition:transform 0.25s ease,opacity 0.25s ease;"></span>
      <span class="bar" style="display:block;width:22px;height:2px;background:var(--text-primary);border-radius:2px;transition:transform 0.25s ease,opacity 0.25s ease;"></span>
    </button>
  </div>

  <!-- Mobile drawer (hidden by default via inline style) -->
  <div
    id="mobile-menu"
    aria-hidden="true"
    style="
      display: none;
      flex-direction: column;
      padding: 16px 24px 28px;
      border-top: 1px solid rgba(255,255,255,0.06);
      background: rgba(5, 8, 16, 0.97);
    "
  >
    <ul role="list" style="list-style:none;margin:0 0 20px;padding:0;">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-link"
            style="
              font-size: 1.05rem;
              font-weight: 500;
              color: var(--text-muted);
              text-decoration: none;
              padding: 14px 0;
              border-bottom: 1px solid rgba(255,255,255,0.06);
              display: block;
              transition: color 0.2s ease;
            "
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <a
      href="#contact"
      style="
        font-weight: 600;
        font-size: 0.9rem;
        padding: 10px 20px;
        border-radius: 8px;
        border: 1px solid transparent;
        background:
          linear-gradient(var(--bg-surface), var(--bg-surface)) padding-box,
          linear-gradient(135deg, var(--accent-purple), var(--accent-cyan)) border-box;
        color: var(--text-primary);
        text-decoration: none;
        align-self: flex-start;
      "
    >
      Launch a Project
    </a>
  </div>
</nav>

<style is:global>
  @media (max-width: 960px) {
    .nav-links,
    .desktop-cta {
      display: none !important;
    }
    #hamburger-btn {
      display: flex !important;
    }
  }
  .nav-link:hover { color: var(--text-primary) !important; }
  .mobile-link:hover { color: var(--text-primary) !important; }
  .nav-cta:hover {
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-cyan)) !important;
    border: 1px solid rgba(255,255,255,0.15) !important;
    transform: translateY(-1px);
  }

  .company-logo {
    height: 1.4em;
    width: auto;
    flex-shrink: 0;
    filter: drop-shadow(0 0 12px rgba(6,182,212,0.3));
  }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById('hamburger-btn');
    var menu = document.getElementById('mobile-menu');
    var bars = btn.querySelectorAll('.bar');

    function openMenu() {
      menu.style.display = 'flex';
      menu.setAttribute('aria-hidden', 'false');
      btn.setAttribute('aria-expanded', 'true');
      bars[0].style.transform = 'translateY(7px) rotate(45deg)';
      bars[1].style.opacity = '0';
      bars[2].style.transform = 'translateY(-7px) rotate(-45deg)';
    }

    function closeMenu() {
      menu.style.display = 'none';
      menu.setAttribute('aria-hidden', 'true');
      btn.setAttribute('aria-expanded', 'false');
      bars[0].style.transform = '';
      bars[1].style.opacity = '';
      bars[2].style.transform = '';
    }

    btn.addEventListener('click', function () {
      if (menu.style.display === 'none' || menu.style.display === '') {
        openMenu();
      } else {
        closeMenu();
      }
    });

    menu.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', closeMenu);
    });
  })();
</script>
