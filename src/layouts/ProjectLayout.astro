---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  category: string;
  projectTitle: string;
  lead: string;
  accent: string;
  accentRgb: string;
  stats: { value: string; label: string }[];
  challenge: string;
  built: string[];
  result: string;
  pricingNote: string;
}

const { title, category, projectTitle, lead, accent, accentRgb, stats, challenge, built, result, pricingNote } = Astro.props;
---

<BaseLayout title={`${projectTitle} — Bit Voyager`}>
  <div class="project-wrap" style={`--accent: ${accent}; --accent-rgb: ${accentRgb};`}>

    <!-- Hero -->
    <section class="project-hero">
      <div class="hero-glow"></div>
      <div class="hero-inner">
        <a href="/bit-voyager/#work" class="back-link">← Back to Work</a>
        <p class="eyebrow">{category}</p>
        <h1>{projectTitle}</h1>
        <p class="lead">{lead}</p>

        <div class="stats-row">
          {stats.map(s => (
            <div class="stat-chip">
              <span class="stat-value">{s.value}</span>
              <span class="stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Body -->
    <div class="project-body">

      <div class="content-card glass-card">
        <div class="card-label">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          The Challenge
        </div>
        <p>{challenge}</p>
      </div>

      <div class="content-card glass-card">
        <div class="card-label">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          What We Built
        </div>
        <ul class="built-list">
          {built.map(item => (
            <li>
              <span class="check">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="content-card glass-card">
        <div class="card-label">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          The Result
        </div>
        <p>{result}</p>
      </div>

      <!-- CTA -->
      <div class="cta-block">
        <div class="cta-glow"></div>
        <p class="cta-eyebrow">// READY TO START?</p>
        <h2>Let's build something together.</h2>
        <p class="cta-note" set:html={pricingNote}></p>
        <a href="/bit-voyager/#contact" class="btn-primary cta-btn">Launch a Project</a>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .project-wrap {
    background: var(--bg-base);
    min-height: 100vh;
  }

  /* ── Hero ── */
  .project-hero {
    position: relative;
    padding: 140px 24px 100px;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 50% 0%, rgba(var(--accent-rgb), 0.18) 0%, transparent 70%),
      linear-gradient(to bottom, var(--bg-base), var(--bg-surface));
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 36px;
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--accent); }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 20px;
  }

  h1 {
    font-size: clamp(2.2rem, 6vw, 3.8rem);
    line-height: 1.1;
    margin-bottom: 24px;
    background: linear-gradient(135deg, var(--text-primary) 60%, rgba(var(--accent-rgb), 0.7));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .lead {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.75;
    max-width: 640px;
    margin-bottom: 48px;
  }

  .stats-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .stat-chip {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: rgba(var(--accent-rgb), 0.08);
    border: 1px solid rgba(var(--accent-rgb), 0.2);
    border-radius: 10px;
    padding: 14px 22px;
    min-width: 110px;
  }

  .stat-value {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── Body ── */
  .project-body {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 24px 120px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .content-card {
    padding: 36px 40px;
    border-left: 2px solid rgba(var(--accent-rgb), 0.4) !important;
  }

  .card-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
  }

  .card-label svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--accent);
  }

  .content-card p {
    color: var(--text-muted);
    line-height: 1.85;
    font-size: 0.97rem;
    margin: 0;
  }

  .built-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px 32px;
  }

  .built-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .check {
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ── CTA ── */
  .cta-block {
    position: relative;
    overflow: hidden;
    background: rgba(var(--accent-rgb), 0.06);
    border: 1px solid rgba(var(--accent-rgb), 0.18);
    border-radius: 16px;
    padding: 56px 48px;
    margin-top: 16px;
    text-align: center;
  }

  .cta-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 50% 120%, rgba(var(--accent-rgb), 0.2), transparent 70%);
    pointer-events: none;
  }

  .cta-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 16px;
    position: relative;
  }

  h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    margin-bottom: 16px;
    position: relative;
  }

  .cta-note {
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.7;
    max-width: 500px;
    margin: 0 auto 32px;
    position: relative;
  }

  .cta-note :global(strong) {
    color: var(--text-primary);
  }

  .cta-btn {
    position: relative;
    display: inline-block;
  }

  @media (max-width: 640px) {
    .built-list { grid-template-columns: 1fr; }
    .content-card { padding: 28px 24px; }
    .cta-block { padding: 40px 24px; }
    .stats-row { gap: 12px; }
    .stat-chip { padding: 12px 16px; min-width: 90px; }
  }
</style>
